{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai/validation-result.schema.json",
  "title": "Forge Runtime Validation Result",
  "description": "Aggregate returned when a workflow validation node completes. Pre-run definition validation uses the aggregate in .ai/data/serialization.md (pre-run shape).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "valid",
    "node_id",
    "workflow_run_id",
    "validated_at",
    "diagnostics",
    "validator_outcomes"
  ],
  "properties": {
    "valid": {
      "type": "boolean"
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_run_id": {
      "type": "string",
      "minLength": 1
    },
    "source_activity_node_id": {
      "type": "string",
      "minLength": 1
    },
    "validated_at": {
      "type": "string",
      "format": "date-time"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    },
    "validator_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/validatorOutcome"
      }
    }
  },
  "$defs": {
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "severity",
        "message",
        "validator_id"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info"
          ]
        },
        "path": {
          "type": "string"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "validator_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "validatorOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "type",
        "passed",
        "blocking"
      ],
      "properties": {
        "validator_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "schema",
            "artifact",
            "domain"
          ]
        },
        "target": {
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        },
        "blocking": {
          "type": "boolean"
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/diagnostic"
          }
        }
      }
    }
  }
}
