{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai/workflow.schema.json",
  "title": "AI Workflow Definition Schema",
  "description": "Contract schema for repo-owned Forge workflow definitions under .ai/workflows/*.json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_id",
    "name",
    "version",
    "entry_node_id",
    "nodes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "entry_node_id": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "retry_policies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/policyRef"
      }
    },
    "timeout_policies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/policyRef"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "type",
        "name"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "activity",
            "validation",
            "human_question",
            "wait",
            "decision",
            "terminal"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "activity_id": {
          "type": "string",
          "minLength": 1
        },
        "agent_path": {
          "type": "string",
          "minLength": 1
        },
        "skill_path": {
          "type": "string",
          "minLength": 1
        },
        "question_id": {
          "type": "string",
          "minLength": 1
        },
        "validators": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/validator"
          }
        },
        "artifact_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "retry_policy": {
          "type": "string",
          "minLength": 1
        },
        "timeout_policy": {
          "type": "string",
          "minLength": 1
        },
        "transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transition"
          }
        }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "to_node_id"
      ],
      "properties": {
        "to_node_id": {
          "type": "string",
          "minLength": 1
        },
        "condition": {
          "type": "string"
        }
      }
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "type"
      ],
      "properties": {
        "validator_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "schema",
            "artifact",
            "domain"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "path"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "policyRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id"
      ],
      "properties": {
        "policy_id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
