{
  "name": "forge-studio",
  "displayName": "Forge Studio",
  "description": "Context engineering for AI-assisted development",
  "version": "3.13.0",
  "license": "MIT",
  "author": "Alto9",
  "publisher": "alto9",
  "keywords": [
    "forge",
    "context-engineering",
    "ai",
    "agentic-development",
    "session-driven",
    "gherkin",
    "specifications"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alto9/forge"
  },
  "bugs": {
    "url": "https://github.com/alto9/forge/issues"
  },
  "homepage": "https://github.com/alto9/forge#readme",
  "engines": {
    "vscode": "^1.80.0",
    "node": ">=22.14.0",
    "npm": ">=10.0.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "chatParticipants": [
      {
        "id": "forge.help.participant",
        "name": "forge-help",
        "fullName": "Forge Help",
        "description": "Workflow guide: explains Forge commands, steps, and handoffs"
      },
      {
        "id": "forge.product-owner.participant",
        "name": "product-owner",
        "fullName": "Product Owner",
        "description": "Step 1: maintains product vision and project direction"
      },
      {
        "id": "forge.architect.participant",
        "name": "architect",
        "fullName": "Architect",
        "description": "Step 2: enforces knowledge map structure and updates domain contracts"
      },
      {
        "id": "forge.planner.participant",
        "name": "planner",
        "fullName": "Planner",
        "description": "Step 3: plans milestones and issues from validated direction"
      },
      {
        "id": "forge.technical-writer.participant",
        "name": "technical-writer",
        "fullName": "Technical Writer",
        "description": "Step 4: refines issues and sub-issues with clear acceptance criteria"
      },
      {
        "id": "forge.engineer.participant",
        "name": "engineer",
        "fullName": "Engineer",
        "description": "Step 5: implements issues, validates tests, and creates pull requests"
      },
      {
        "id": "forge.quality-assurance.participant",
        "name": "quality-assurance",
        "fullName": "Quality Assurance",
        "description": "Step 6: reviews pull requests for correctness and security"
      }
    ],
    "commands": [
      {
        "command": "forge.initializeAgents",
        "title": "Forge: Initialize Cursor Agents"
      },
      {
        "command": "forge.initializeProject",
        "title": "Forge: Initialize Project"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "webpack --mode production --devtool hidden-source-map",
    "compile": "webpack",
    "build": "webpack",
    "watch": "webpack --watch",
    "package": "npx @vscode/vsce package --no-dependencies",
    "build:webview": "echo No webviews",
    "dev:webview": "echo No webviews",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts,tsx",
    "test": "vitest run",
    "clean": "rm -rf dist out *.vsix node_modules",
    "release:dry-run": "semantic-release --dry-run",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@semantic-release/npm": "^13.1.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@tiptap/extension-image": "^3.10.4",
    "@tiptap/extension-link": "^3.10.4",
    "@tiptap/react": "^3.10.4",
    "@tiptap/starter-kit": "^3.10.4",
    "@types/node": "^22.14.0",
    "@types/react": "^18.2.73",
    "@types/react-dom": "^18.2.18",
    "@types/turndown": "^5.0.6",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/ui": "^4.0.15",
    "@vscode/vsce": "^3.2.1",
    "concurrently": "^8.2.2",
    "conventional-changelog-conventionalcommits": "^7.0.2",
    "esbuild": "0.19.12",
    "eslint": "^8.0.0",
    "happy-dom": "^20.0.11",
    "marked": "^17.0.0",
    "semantic-release": "^25.0.2",
    "ts-loader": "^9.5.4",
    "turndown": "^7.2.2",
    "typescript": "^5.0.0",
    "vitest": "^4.0.15",
    "webpack": "^5.102.0",
    "webpack-cli": "^6.0.1"
  },
  "overrides": {
    "@actions/http-client": {
      "undici": "^6.24.0"
    }
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "gray-matter": "^4.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.6.0",
    "zustand": "^5.0.8"
  }
}
